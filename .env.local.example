# Environment Variables Example
# Copy this file to .env.local and fill in your values

# Polygon/Ethereum (for NFT minting)
NEXT_PUBLIC_POLYGON_RPC_URL=
POLYGON_PRIVATE_KEY=

# BNPL Integration (Tabby/Tamara)
TABBY_SECRET_KEY=
TABBY_PUBLIC_KEY=
TAMARA_API_KEY=

# Payment Gateway
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Database
DATABASE_URL=

# JWT Secret
JWT_SECRET=

# AWS S3 (for file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=
